{
  "name": "js-simulator",
  "version": "0.0.0",
  "description": "A React + TypeScript design system.",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/js-simulator.cjs",
  "module": "./dist/js-simulator.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/js-simulator.js",
      "require": "./dist/js-simulator.cjs"
    },
    "./styles.css": "./dist/js-simulator.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --p tsconfig.build.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-dts": "^4.3.0"
  },
  "dependencies": {
    "framer-motion": "^12.42.2",
    "react-router-dom": "^7.18.1"
  }
}
